# vim:ft=swayconfig
# @author wkai
# @since 2023,2024,2025,2026


# ~/.config/sway/rules 
# 全局浮动与弹窗规则 (确保交互逻辑符合直觉)
# 自动让所有的弹窗、对话框和菜单居中浮动，防止它们被平铺充满屏幕
for_window [window_role="pop-up"] floating enable, move position center
for_window [window_role="task_dialog"] floating enable, move position center
for_window [window_type="dialog"] floating enable, move position center
for_window [window_type="menu"] floating enable
# 兼容性补丁：强制所有 XWayland 应用（旧版非原生应用）的对话框浮动
# for_window [shell="xwayland"] floating enable


# 系统组件与基础工具配置
# 权限认证代理：执行 sudo 操作时的弹窗
for_window [class="Polkit-gnome-authentication-agent-1"] floating enable, move position center
# 输入法配置界面
for_window [app_id="fcitx5-config-qt"] floating enable
# 音量控制面板：固定尺寸并居中
for_window [app_id="pavucontrol"] floating enable, resize set width 800 px height 600 px
# 截图标注工具 (Swappy)
for_window [app_id="swappy"] floating enable, move position center
# 防止 Kitty 这种终端在某些特定操作下出现微小边框
for_window [app_id="kitty"] border none


# 3. 特定应用程序规则
# 让特定的监控窗口自动浮动=浮动终端监控 
for_window [app_id="sysmon"] floating enable, resize set 1200 800, move position center
# clash-verge=使用 assign 分配工作区->使用 for_window 处理浮动和位置（针对已经分配到工作区 9 的窗口）
for_window [app_id="clash-verge"] {
    move container to workspace number 9
    floating enable
    resize set 1000 650
    move position center
}
# 让 KCalc 自动浮动并居中=计算器
for_window [app_id="kcalc"] floating enable, move position center
# 将浏览器固定在第 2 个工作区!!原生 Wayland，使用 app_id)
for_window [app_id="google-chrome"] move container to workspace number 2
# 将 YesPlayMusic 自动分配到第 10 个工作区!!XWayland，必须使用 class
for_window [class="yesplaymusic"] move container to workspace number 10
# 让音乐播放器启动时不要自动夺取焦点
no_focus [class="yesplaymusic"]
# 将 QQ 分配到第 4 个工作区,linuxqq 通常使用 app_id (Wayland 原生)
assign [class="QQ"] workspace number 4
# 将微信分配到第 4 个工作区,微信 Universal 版本通常运行在 XWayland 下，使用 class
assign [class="wechat"] workspace number 4


# 优化 Firefox 画中画窗口（Picture-in-Picture）
# 优化 Firefox 画中画：sticky 确保切工作区它也在，位置设为右下角
for_window [title="Picture-in-Picture"] {
    floating enable
    sticky enable
    # 移动到右下角，保留一定边距
    move position 75ppt 70ppt 
}

# 增加：让所有的录屏/选择框（slurp）不要有边框
for_window [app_id="slurp"] border none

# 加对 JetBrains 系 IDE 弹窗的补丁
for_window [instance="jetbrains-.*" title="^ "] floating enable

# imv 加一个浮动规则
# for_window [app_id="imv"] floating enable, move position center, resize set 1000 700
# nsxiv 窗口规则 (使用 class 匹配 XWayland 应用)
for_window [class="nsxiv"] {
    floating enable
    move position center
    resize set 1200 800
    # 允许它在所有工作区可见
    sticky enable 
}
