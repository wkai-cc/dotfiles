# vim:ft=swayconfig
# @author wkai
# @since 2023,2024,2025,2026


# ~/.config/sway/bindings
### 基础快捷键
# 手动锁屏 (mod +Alt+ L)
# bindsym $mod+Alt+l exec swaylock -i /home/wkai/Pictures/wallpaper_7.png
bindsym $mod+Alt+l exec $lock_cmd
# 启动终端 (mod + Enter)
bindsym $mod+Return exec $term
# 关闭当前焦点窗口 (mod + Shift + Q)
bindsym $mod+Shift+q kill
# 打开应用菜单 (mod + D)
bindsym $mod+d exec $menu
# 按住 mod 键可用鼠标左键拖动浮动窗口
floating_modifier $mod normal
# 重载 Sway 配置文件 (mod + Shift + C)
bindsym $mod+Shift+c reload
# 退出 Sway 会话 (mod + Shift + E)
bindsym $mod+Shift+e exec swaynag -t warning -m 'You pressed the exit shortcut. Do you really want to exit sway? This will end your Wayland session.' -B 'Yes, exit sway' 'swaymsg exit'
# 壁纸切换 (mod + Shift + W)
# bindsym $mod+Shift+w exec ~/.local/bin/change_wallpaper.sh
bindsym $mod+Shift+w exec ~/.local/bin/wallpaper-picker.sh
# 剪切板=bindings(mod + v)
bindsym $mod+v exec cliphist list | rofi -dmenu | cliphist decode | wl-copy
# 表情包=rofi-emoji(mod + )
bindsym $mod+period exec rofi -show emoji
# 启动计算器(mod + c)
bindsym $mod+c exec $calc
# 打开 Google Chrome(mod + g)
bindsym $mod+g exec $browser
# 打开 YesPlayMusic(mod + m)
bindsym $mod+m exec $music
# 直接打开图片文件夹(mod + Shift +i)
# bindsym $mod+Shift+i exec find ~/Pictures -maxdepth 1 -type d | rofi -dmenu -i -p "选择图片目录" | xargs -I {} imv "{}"
# 使用 nsxiv 并添加 -t 参数，这样打开文件夹直接就是缩略图模式
bindsym $mod+Shift+i exec find ~/Pictures -maxdepth 1 -type d | rofi -dmenu -i -p "选择图片目录" | xargs -I {} nsxiv -t "{}"


### 焦点切换 (Focus)
# 使用 mod + HJKL 或 方向键切换窗口焦点
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

### 窗口移动 (Move)
# 使用 mod + Shift + HJKL 或 方向键移动窗口位置
bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

### 工作区管理 (Workspaces)
# 使用 mod + 数字键切换工作区
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10
# 使用 mod + Shift + 数字键将当前窗口移至对应工作区
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

### 布局控制 (Layout)
# 浮动终端监控
bindsym $mod+Escape exec kitty --class sysmon -e btop
# 动态增加/减少间隙 (mod + Alt + 加号/减号)
bindsym $mod+Alt+equal gaps inner current plus 5
bindsym $mod+Alt+minus gaps inner current minus 5
# 重置当前工作区的间隙为 0 (或者你喜欢的默认值)
bindsym $mod+Alt+0 gaps inner current set 0
# 切换水平/垂直分割
bindsym $mod+b splith
bindsym $mod+n splitv
# 切换堆叠/标签页/平铺布局
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
# 切换全屏
bindsym $mod+f fullscreen
# 切换当前窗口是否浮动
bindsym $mod+Shift+space floating toggle
# 在平铺窗口和浮动窗口之间切换焦点
bindsym $mod+space focus mode_toggle
# 聚焦到父容器
bindsym $mod+a focus parent

### 临时工作区 (Scratchpad)
# 将窗口移动到临时工作区（隐藏）
bindsym $mod+Shift+minus move scratchpad
# 循环显示/隐藏临时工作区中的窗口
bindsym $mod+minus scratchpad show
### 多媒体按键 (Utilities)
# 音量控制 (使用 wpctl 适配 PipeWire)
bindsym --locked XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym --locked XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym --locked XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym --locked XF86AudioMicMute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
# 台式机亮度调节 (使用 ddcutil 控制显示器硬件)
bindsym --locked XF86MonBrightnessDown exec "ddcutil setvcp 10 - 10 --noverify &"
bindsym --locked XF86MonBrightnessUp exec "ddcutil setvcp 10 + 10 --noverify &"
# mod + p 开启护眼模式 (强制色温为 5000K)
bindsym $mod+p exec "pkill wlsunset; wlsunset -t 4999 -T 5000"
# mod + o 关闭护眼模式 (结束进程)
bindsym $mod+o exec "pkill wlsunset; exec sleep 1 && wlsunset -l 25.0 -L 102.4 -t 5000 -T 6500"

# 截图快捷键 (Print Screen)
# 区域截图并自动复制到剪贴板
# bindsym Print exec grim -g "$(slurp)" - | wl-copy
# bindsym Print exec grim -g "$(slurp)" - | tee ~/Pictures/$(date +%Y%m%d_%H%M%S).png | wl-copy
bindsym Print exec grim -g "$(slurp)" - | tee ~/Pictures/$(date +%Y%m%d_%H%M%S).png | swappy -f -

# 录屏设置=wf-recorder
# 区域录屏 (Mod + Alt + R)
bindsym $mod+Alt+r exec ~/.local/bin/recorder.sh
# 全屏录屏 (Mod + Shift + Alt + R)
bindsym $mod+Shift+Alt+r exec ~/.local/bin/recorder.sh full

# 开启/关闭按键显示 (Mod + Alt + K)=wshowkeys
bindsym $mod+Alt+k exec pgrep -x wshowkeys && pkill -x wshowkeys || wshowkeys -a bottom -m 10 -b "#2b3339aa" -f "#a7c080"

